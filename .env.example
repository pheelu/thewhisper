# ---- App ----
APP_ENV=dev
# Segreto per firmare i token di sessione per-evento (cambia in produzione!)
SECRET_KEY=change-me-dev-secret-please-rotate
# Origini CORS ammesse (frontend Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- PostgreSQL ----
POSTGRES_USER=whisper
POSTGRES_PASSWORD=whisper
POSTGRES_DB=whisper
POSTGRES_PORT=5432
# URL async usato da SQLAlchemy/asyncpg
DATABASE_URL=postgresql+asyncpg://whisper:whisper@localhost:5432/whisper

# ---- MinIO / S3 ----
MINIO_ROOT_USER=whisper
MINIO_ROOT_PASSWORD=whisper-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=whisper
S3_SECRET_KEY=whisper-secret
S3_BUCKET=whisper-photos
S3_REGION=us-east-1
# Base URL pubblico per servire le foto (in dev = MinIO diretto)
S3_PUBLIC_URL=http://localhost:9000/whisper-photos

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
